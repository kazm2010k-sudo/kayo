@bot.callback_query_handler(func=lambda call: True)
def handle_callback(call):
    """معالجة الضغط على الأزرار"""
    user_id = call.from_user.id
    
    if user_id not in ADMINS:
        bot.answer_callback_query(call.id, "⛔ غير مخول")
        return
    
    if call.data == "upload_photo":
        bot.answer_callback_query(call.id, "📤 أرسل الصورة الآن")
        bot.send_message(call.message.chat.id, "📤 أرسل الصورة التي تريد رفعها")
        
    elif call.data == "list_photos":
        bot.answer_callback_query(call.id, "📋 جاري تحميل الصور...")
        list_photos(call.message)
        
    elif call.data == "manage_admins":
        bot.answer_callback_query(call.id, "👥 إدارة الأدمن")
        manage_admins_menu(call.message)
        
    elif call.data.startswith("delete_photo_"):
        unique_id = call.data.replace("delete_photo_", "")
        if delete_photo_files(unique_id):
            bot.answer_callback_query(call.id, "✅ تم الحذف")
            bot.send_message(call.message.chat.id, f"✅ تم حذف الصورة {unique_id} بنجاح")
        else:
            bot.answer_callback_query(call.id, "❌ فشل الحذف")
            bot.send_message(call.message.chat.id, f"❌ فشل حذف الصورة {unique_id}")

def list_photos(message):
    """عرض قائمة الصور"""
    index_file = os.path.join(UPLOAD_FOLDER, "files_index.txt")
    if not os.path.exists(index_file):
        bot.send_message(message.chat.id, "📭 لا توجد صور مرفوعة")
        return
    
    photos = []
    with open(index_file, 'r') as f:
        for line in f:
            parts = line.strip().split(':')
            if len(parts) >= 2:
                photos.append({
                    'id': parts[0],
                    'filename': parts[1]
                })
    
    if not photos:
        bot.send_message(message.chat.id, "📭 لا توجد صور مرفوعة")
        return
    
    # عرض الصور مع أزرار التحكم
    for photo in photos[:5]:  # عرض أول 5 صور فقط
        markup = telebot.types.InlineKeyboardMarkup(row_width=1)
        btn_delete = telebot.types.InlineKeyboardButton("🗑️ حذف", callback_data=f"delete_photo_{photo['id']}")
        markup.add(btn_delete)
        
        # إرسال الصورة مع معلوماتها
        filepath = os.path.join(UPLOAD_FOLDER, photo['filename'])
        if os.path.exists(filepath):
            with open(filepath, 'rb') as img:
                caption = f"🆔: {photo['id']}"
                bot.send_photo(message.chat.id, img, caption=caption, reply_markup=markup)
        else:
            bot.send_message(
                message.chat.id,
                f"🆔: {photo['id']}\n⚠️ الملف غير موجود",
                reply_markup=markup
            )
    
    if len(photos) > 5:
        bot.send_message(message.chat.id, f"📊 يوجد {len(photos)} صورة. تم عرض أول 5")

