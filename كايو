ADMINS_FILE = "admins.txt"

def load_admins():
    """تحميل قائمة الأدمن من ملف"""
    global ADMINS
    if os.path.exists(ADMINS_FILE):
        with open(ADMINS_FILE, 'r') as f:
            admins = f.read().strip().split(',')
            ADMINS = {int(a) for a in admins if a.strip()}
            ADMINS.add(OWNER_ID)
            ADMINS.add(ADMIN_ID)
    else:
        ADMINS = {OWNER_ID, ADMIN_ID}
        save_admins()

def save_admins():
    """حفظ قائمة الأدمن في ملف"""
    with open(ADMINS_FILE, 'w') as f:
        f.write(','.join(str(a) for a in ADMINS))

