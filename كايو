def generate_internal_link(file_id):
    """توليد رابط داخلي للبوت"""
    bot_username = bot.get_me().username
    return f"https://t.me/{bot_username}?start={file_id}"

def save_photo(file_id, user_id):
    """حفظ الصورة وإرجاع معرف فريد"""
    try:
        file_info = bot.get_file(file_id)
        downloaded_file = bot.download_file(file_info.file_path)
        
        # إنشاء معرف فريد للصورة
        unique_id = str(uuid.uuid4())[:8]
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        filename = f"{timestamp}_{unique_id}.jpg"
        filepath = os.path.join(UPLOAD_FOLDER, filename)
        
        with open(filepath, 'wb') as f:
            f.write(downloaded_file)
        
        # حفظ معلومات الصورة في ملف
        with open(os.path.join(UPLOAD_FOLDER, "files_index.txt"), 'a') as f:
            f.write(f"{unique_id}:{filename}:{user_id}\n")
        
        return unique_id, filename
    except Exception as e:
        print(f"خطأ في حفظ الصورة: {e}")
        return None, None

def get_photo_data(unique_id):
    """استرجاع بيانات الصورة من الفهرس"""
    index_file = os.path.join(UPLOAD_FOLDER, "files_index.txt")
    if os.path.exists(index_file):
        with open(index_file, 'r') as f:
            for line in f:
                parts = line.strip().split(':')
                if len(parts) >= 2 and parts[0] == unique_id:
                    return {
                        'unique_id': parts[0],
                        'filename': parts[1],
                        'user_id': int(parts[2]) if len(parts) > 2 else 0
                    }
    return None

def delete_photo_files(unique_id):
    """حذف ملفات الصورة"""
    photo_data = get_photo_data(unique_id)
    if not photo_data:
        return False
    
    # حذف الملف
    filepath = os.path.join(UPLOAD_FOLDER, photo_data['filename'])
    if os.path.exists(filepath):
        os.remove(filepath)
    
    # حذف من الفهرس
    index_file = os.path.join(UPLOAD_FOLDER, "files_index.txt")
    if os.path.exists(index_file):
        lines = []
        with open(index_file, 'r') as f:
            lines = f.readlines()
        
        with open(index_file, 'w') as f:
            for line in lines:
                if not line.startswith(f"{unique_id}:"):
                    f.write(line)
        return True
    return False

